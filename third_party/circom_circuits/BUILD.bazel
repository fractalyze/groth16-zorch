load("@r1cs_solver//bazel:mlir.bzl", "prime_ir_mlir_cc_import")
load("@rules_cc//cc:defs.bzl", "cc_binary")

package(default_visibility = ["//visibility:public"])

# Concatenate runtime + circuit MLIR (same pattern as @r1cs_solver//circom).
# Runtime files (types.mlir, helpers.mlir, circom_runtime.mlir) are copied from
# r1cs-solver/circom/ since they are not exported by the external workspace.
genrule(
    name = "multiplier_3_combined",
    srcs = [
        "types.mlir",
        "helpers.mlir",
        "circom_runtime.mlir",
        "multiplier_3.mlir",
    ],
    outs = ["multiplier_3_combined.mlir"],
    cmd = "cat $(SRCS) > $@",
)

prime_ir_mlir_cc_import(
    name = "multiplier_3_ciface",
    llc_flags = ["-mcpu=native"],
    mlir_src = ":multiplier_3_combined",
    prime_ir_opt_flags = ["-field-to-llvm"],
)

# Shared library for Python ctypes loading.
# No mlir_c_runner_utils — all MLIR ops are lowered to LLVM IR by
# prime-ir-opt. Avoids LLVM static destructor conflict with libr1cs_solver.so.
cc_binary(
    name = "libmultiplier_3.so",
    linkshared = True,
    deps = [":multiplier_3_ciface"],
)
