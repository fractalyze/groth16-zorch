# syntax=docker/dockerfile:1.6
#
# Rabbit groth16 benchmark image for NVIDIA GPUs (CUDA 12.x).
#
# Mirrors Dockerfile.rocm structure for symmetric C2-vs-C3 measurement
# through the `benchmark-on-rented-gpu` plugin
# (fractalyze/claude-plugins#43). Same source, same solver build, same
# benchmark entrypoint — only the runtime base image and the lockfile
# differ.
#
# Two stages:
#   1. solver-build (ubuntu:22.04 + bazel) — same as Dockerfile.rocm.
#      Produces `libr1cs_solver.so` from rabbit source. The solver is
#      MLIR→LLVM→CPU, hardware-agnostic, so this stage could be
#      shared between Dockerfile.cuda and Dockerfile.rocm via a
#      common base image build if image build time becomes a bottleneck.
#
#   2. runtime (nvidia/cuda:12.x-cudnn-runtime-ubuntu22.04) —
#      Python 3.11 + jax_fork CUDA wheels from
#      `requirements_lock_3_11.txt` (which carries the `[with-cuda]`
#      extra and pulls 13 nvidia-* runtime packages — see personal memo
#      `jax-cuda12-plugin-needs-with-cuda-extra-for-runtime-libs-2026-05-29`).
#      The CUDA base image provides cuDNN at the OS level; the wheel
#      runtime libs ride on top.

ARG BAZEL_VERSION=7.4.1
# Matches the cuDNN version pinned in requirements_lock_3_11.txt
# (nvidia-cudnn-cu12==9.22.0.52, cuDNN 9.x — needs CUDA 12.9 runtime).
ARG CUDA_TAG=12.9.1-cudnn-runtime-ubuntu22.04

# ----------------------------------------------------------------------
# Stage 1: bazel-build libr1cs_solver.so
# ----------------------------------------------------------------------
FROM ubuntu:22.04 AS solver-build

ARG BAZEL_VERSION

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git build-essential \
        python3.11 python3.11-dev python3.11-venv \
        unzip zip \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION}/bazel-${BAZEL_VERSION}-linux-x86_64" \
        -o /usr/local/bin/bazel \
    && chmod +x /usr/local/bin/bazel

WORKDIR /work
COPY . /work
RUN bazel build -c opt @r1cs_solver//solver:libr1cs_solver.so \
    && cp bazel-bin/external/r1cs_solver/solver/libr1cs_solver.so /work/libr1cs_solver.so

# ----------------------------------------------------------------------
# Stage 2: CUDA runtime + rabbit
# ----------------------------------------------------------------------
FROM nvidia/cuda:${CUDA_TAG} AS runtime

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl \
        python3.11 python3.11-dev python3.11-venv \
        libpython3.11 \
    && rm -rf /var/lib/apt/lists/*

RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:${PATH}"

WORKDIR /rabbit

# CUDA lockfile carries `jax-cuda12-plugin[with-cuda]` which pulls the
# 13 nvidia-* runtime wheels — they sit alongside the cuDNN provided
# by the base image. JAX's plugin discovery prefers the pip-installed
# libraries via rpath, so the base-image cuDNN is the fallback for
# anything the wheels don't bundle (in practice, none on CUDA 12.x).
COPY requirements_lock_3_11.txt /rabbit/requirements_lock_3_11.txt
RUN pip install --upgrade pip \
    && pip install -r requirements_lock_3_11.txt

COPY rabbitsnark/ /rabbit/rabbitsnark/
COPY benchmark/   /rabbit/benchmark/

COPY --from=solver-build /work/libr1cs_solver.so /opt/lib/libr1cs_solver.so

ENV PYTHONPATH=/rabbit
ENV R1CS_SOLVER_LIB=/opt/lib/libr1cs_solver.so
ENV XLA_PYTHON_CLIENT_PREALLOCATE=false
ENV JAX_PLATFORMS=cuda,cpu

RUN mkdir -p /data/sp1-groth16 /output

ENTRYPOINT ["python", "-m", "benchmark.sp1_groth16"]
CMD ["--export_dir=/data/sp1-groth16", \
     "--deterministic", "--warmup=2", "--iterations=10", \
     "--output=/output/c2_nvidia_result.json"]
